APP_NAME=Local Work Marketplace API
APP_VERSION=1.0.0
DEBUG=true

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=local_work_marketplace

# Clerk Auth
CLERK_SECRET_KEY=sk_test_...
CLERK_JWKS_URL=https://<your-clerk-domain>/.well-known/jwks.json
CLERK_ISSUER=https://<your-clerk-domain>

# Firebase
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json
ENABLE_FIREBASE_STORAGE=false
FIREBASE_STORAGE_BUCKET=your-project.appspot.com

# CORS
CORS_ORIGINS=http://localhost:8081,exp://192.168.1.100:8081

# Rate Limits
RATE_LIMIT_AUTH_PER_HOUR=10
RATE_LIMIT_CONVERSATIONS_PER_DAY=20
MAX_ACTIVE_JOBS_PER_DAY=3
MAX_IMAGE_SIZE_MB=10
